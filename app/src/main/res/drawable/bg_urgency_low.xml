<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/secondary_container" />
            <corners android:radius="12dp" />
            <stroke android:width="2dp" android:color="@color/secondary" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_container_low" />
            <corners android:radius="12dp" />
            <stroke android:width="2dp" android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>